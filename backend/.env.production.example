# Copy to /opt/ads-mangment/backend/.env on the EC2 host and fill in real values.
# NEVER commit this file with real secrets.

NODE_ENV=production
PORT=3800

# --- Database (local Postgres on the EC2 host) ---
DATABASE_URL=postgres://ads_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/ads_dashboard

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_OF_RANDOM
DEFAULT_ADMIN_EMAIL=admin@yourcompany.com
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- CORS (frontend origin served by nginx on the same host) ---
# Comma-separated list, e.g. http://1.2.3.4,https://ads.yourcompany.com
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP

# --- Fireberry (PowerLink) ---
FIREBERRY_TOKEN=
FIREBERRY_API_URL=https://api.powerlink.co.il/api

# --- Meta / Facebook ---
META_BUSINESS_ID=
META_BUSINESS_TOKEN=
META_API_VERSION=v21.0

# --- Media storage on S3 ---
# Target:   s3://iconiq-backups/ads/
# Public:   https://iconiq-backups.s3.eu-north-1.amazonaws.com/ads/
MEDIA_STORAGE=s3
S3_BUCKET=iconiq-backups
S3_REGION=eu-north-1
S3_PREFIX=ads
# S3_PUBLIC_BASE_URL is optional — leave unset to use the bucket's default host.
# S3_PUBLIC_BASE_URL=https://iconiq-backups.s3.eu-north-1.amazonaws.com
# AWS credentials: prefer an IAM instance profile attached to the EC2 host.
# If not using an instance profile, set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here.

# --- AI (optional) ---
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# --- Misc ---
DOWNLOAD_VIDEOS=false
LOG_LEVEL=INFO
